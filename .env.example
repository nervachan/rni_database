# Backend (Express API in /api, runs as a Vercel serverless function in prod)

# Supabase project URL + key (service role or anon, depending on what the API needs)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# =============================================================================
# FIREBASE ADMIN CREDENTIALS (see firebase.cjs for how this is loaded)
# =============================================================================
# Two ways to provide this — firebase.cjs checks both, in this order:
#
# OPTION A — Production (Vercel). REQUIRED for production to work at all.
#   firebase-service-account.json is gitignored, so Vercel never receives it
#   through a normal Git push — this env var is the only way production
#   gets the credential.
#
#   Step 1: generate the base64 string from your local
#           firebase-service-account.json:
#             node -e "console.log(Buffer.from(require('fs').readFileSync('firebase-service-account.json')).toString('base64'))"
#   Step 2: copy the ENTIRE output (it's one long line) and set it as the
#           value of FIREBASE_SERVICE_ACCOUNT_BASE64 below.
#   Step 3: this must ALSO be set in Vercel directly — Vercel does not read
#           your local .env file. Go to: Vercel dashboard > this project >
#           Settings > Environment Variables > Add New, name it
#           FIREBASE_SERVICE_ACCOUNT_BASE64, paste the same value, then
#           redeploy (env var changes only apply to NEW deployments).
#
# OPTION B — Local development only.
#   Leave this blank in your real .env and instead just keep the raw
#   firebase-service-account.json file in the repo root (gitignored,
#   never committed). firebase.cjs falls back to reading that file
#   directly whenever this env var is empty.
#
# You don't need both — pick whichever is easiest for local dev, but
# Option A is mandatory for the Vercel deployment specifically.
# -----------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Restrict CORS to your deployed frontend origin. Leave unset ("*") for local dev.
FRONTEND_URL=

# Port for the local Express dev server (node index.cjs)
PORT=3000

# Only needed if your local backend runs on a different port than 3000
# (used by the Vite dev server proxy for /api requests)
BACKEND_URL=http://localhost:3000
